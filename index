<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Suriyawong Jongkhae (Tiger) — Performance Ads Specialist</title>
<style>
/* ─── RESET & BASE ─── */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; font-size: 16px; }

body {
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  background: #F8F8F6;
  color: #1A1A1A;
  line-height: 1.6;
  overflow-x: hidden;
}

/* ─── CSS VARIABLES ─── */
:root {
  --black: #0D0D0D;
  --white: #FFFFFF;
  --cream: #F8F8F6;
  --gray-1: #F2F2F0;
  --gray-2: #E8E8E6;
  --gray-3: #B8B8B6;
  --gray-4: #888888;
  --accent: #1A1AFF;
  --accent-2: #FF3B00;
  --accent-3: #00C851;
  --text: #1A1A1A;
  --text-mid: #444444;
  --text-muted: #888888;
}

/* ─── TYPOGRAPHY SCALE ─── */
.f-80 { font-size: clamp(48px, 6vw, 80px); }
.f-56 { font-size: clamp(36px, 4.5vw, 56px); }
.f-40 { font-size: clamp(28px, 3vw, 40px); }
.f-28 { font-size: clamp(20px, 2.2vw, 28px); }
.f-18 { font-size: 18px; }
.f-14 { font-size: 14px; }
.f-11 { font-size: 11px; }
.fw-900 { font-weight: 900; }
.fw-700 { font-weight: 700; }
.fw-500 { font-weight: 500; }
.fw-400 { font-weight: 400; }
.fw-300 { font-weight: 300; }
.ls-wide { letter-spacing: 0.12em; }
.ls-tight { letter-spacing: -0.03em; }
.uppercase { text-transform: uppercase; }
.italic { font-style: italic; }

/* ─── NAV ─── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  height: 56px;
  background: rgba(248,248,246,0.92);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--gray-2);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 6%;
}
.nav-logo {
  font-size: 13px; font-weight: 700; letter-spacing: 0.06em;
  text-transform: uppercase; color: var(--black);
}
.nav-links {
  display: flex; gap: 36px; list-style: none;
}
.nav-links a {
  font-size: 12px; font-weight: 500; letter-spacing: 0.06em;
  text-transform: uppercase; color: var(--text-muted);
  text-decoration: none; transition: color 0.2s;
}
.nav-links a:hover { color: var(--black); }
.nav-cta {
  background: var(--black); color: var(--white) !important;
  padding: 8px 20px; border-radius: 2px; font-size: 11px !important;
  font-weight: 700 !important;
}
.nav-cta:hover { background: var(--accent) !important; color: var(--white) !important; }

/* ─── HERO ─── */
#hero {
  min-height: 100vh;
  padding: 0 6%;
  display: flex; align-items: center;
  position: relative; overflow: hidden;
  background: var(--black);
}

.hero-bg-text {
  position: absolute; right: -2%;
  font-size: clamp(120px, 18vw, 220px);
  font-weight: 900; line-height: 1;
  color: rgba(255,255,255,0.04);
  letter-spacing: -0.04em;
  text-transform: uppercase;
  user-select: none; pointer-events: none;
  white-space: nowrap;
}

.hero-grid-line {
  position: absolute; top: 0; bottom: 0;
  width: 1px; background: rgba(255,255,255,0.06);
}

.hero-inner {
  max-width: 1200px; margin: 0 auto; width: 100%;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 80px; align-items: center;
  padding-top: 56px;
}

.hero-label {
  display: inline-flex; align-items: center; gap: 10px;
  font-size: 11px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--accent);
  margin-bottom: 24px;
}
.hero-label::before {
  content: ''; display: block;
  width: 28px; height: 1px; background: var(--accent);
}

.hero-name {
  font-size: clamp(52px, 7vw, 88px);
  font-weight: 900; line-height: 0.95;
  letter-spacing: -0.04em; color: var(--white);
  margin-bottom: 4px;
}
.hero-name .accent { color: var(--accent); }

.hero-role {
  font-size: clamp(14px, 1.5vw, 18px);
  font-weight: 300; color: rgba(255,255,255,0.5);
  letter-spacing: 0.04em; margin-bottom: 32px;
}
.hero-role strong { color: var(--white); font-weight: 500; }

.hero-tagline {
  font-size: clamp(22px, 2.8vw, 34px);
  font-weight: 700; line-height: 1.25;
  color: var(--white); margin-bottom: 40px;
  letter-spacing: -0.02em;
}
.hero-tagline .line2 { color: rgba(255,255,255,0.45); font-weight: 300; }

.hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }
.btn-white {
  background: var(--white); color: var(--black);
  padding: 14px 32px; font-size: 12px; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  text-decoration: none; border: 1px solid var(--white);
  transition: all 0.2s; display: inline-block;
}
.btn-white:hover { background: var(--accent); border-color: var(--accent); color: var(--white); }
.btn-ghost {
  background: transparent; color: var(--white);
  padding: 14px 32px; font-size: 12px; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  text-decoration: none; border: 1px solid rgba(255,255,255,0.3);
  transition: all 0.2s; display: inline-block;
}
.btn-ghost:hover { border-color: var(--white); }

/* Hero stats card */
.hero-right { display: flex; flex-direction: column; gap: 16px; }

.hero-stat-row {
  display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.1);
  margin-bottom: 0;
}
.hero-stat-box {
  background: rgba(255,255,255,0.04);
  padding: 24px 20px;
}
.hero-stat-val {
  font-size: clamp(28px, 3.5vw, 42px);
  font-weight: 900; line-height: 1;
  letter-spacing: -0.03em; color: var(--white);
  margin-bottom: 4px;
}
.hero-stat-val .unit { font-size: 0.5em; font-weight: 400; color: rgba(255,255,255,0.5); }
.hero-stat-lbl { font-size: 11px; color: rgba(255,255,255,0.4); letter-spacing: 0.06em; text-transform: uppercase; }

.platform-row {
  display: flex; flex-wrap: wrap; gap: 8px;
}
.plat-badge {
  font-size: 10px; font-weight: 700; letter-spacing: 0.08em;
  text-transform: uppercase; padding: 6px 14px;
  border: 1px solid rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.7);
}
.plat-badge.active {
  background: var(--accent); border-color: var(--accent); color: var(--white);
}

.hero-avail {
  display: flex; align-items: center; gap: 10px;
  font-size: 12px; color: rgba(255,255,255,0.5);
  padding: 14px 16px;
  border: 1px solid rgba(255,255,255,0.1);
}
.avail-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--accent-3);
  animation: blink 2s infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.4} }

/* ─── TICKER ─── */
.ticker-wrap {
  background: var(--accent); overflow: hidden;
  padding: 14px 0; white-space: nowrap;
}
.ticker-inner {
  display: inline-flex; animation: ticker 30s linear infinite;
}
.ticker-item {
  font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--white);
  padding: 0 40px;
}
.ticker-sep { color: rgba(255,255,255,0.5); }
@keyframes ticker { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

/* ─── SECTIONS ─── */
section { padding: 100px 6%; }
.container { max-width: 1200px; margin: 0 auto; }

.section-label {
  font-size: 11px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--text-muted);
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 20px;
}
.section-label::before {
  content: ''; width: 24px; height: 1px; background: var(--text-muted);
}

.section-title {
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 900; letter-spacing: -0.03em;
  line-height: 1.05; color: var(--black);
  margin-bottom: 16px;
}

.section-sub {
  font-size: 16px; color: var(--text-muted);
  line-height: 1.7; max-width: 600px;
}

/* ─── WHY HIRE ME ─── */
#why { background: var(--white); }

.why-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 2px; background: var(--gray-2);
  margin-top: 56px;
}
.why-card {
  background: var(--white); padding: 44px 40px;
  transition: background 0.25s;
  position: relative; overflow: hidden;
}
.why-card::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0;
  width: 3px; background: var(--accent);
  transform: scaleY(0); transform-origin: bottom;
  transition: transform 0.3s;
}
.why-card:hover::before { transform: scaleY(1); }
.why-card:hover { background: #FAFAFE; }
.why-num {
  font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
  color: var(--accent); text-transform: uppercase; margin-bottom: 20px;
}
.why-title {
  font-size: 20px; font-weight: 700; letter-spacing: -0.02em;
  color: var(--black); margin-bottom: 12px;
}
.why-body { font-size: 14px; color: var(--text-mid); line-height: 1.75; }

/* ─── CASE STUDIES ─── */
#results { background: var(--cream); }

.result-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 2px; background: var(--gray-2); margin-top: 56px;
}
.result-card {
  background: var(--white); padding: 40px 36px;
  display: flex; flex-direction: column;
}
.result-industry {
  font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--text-muted); margin-bottom: 20px;
  padding-bottom: 12px; border-bottom: 1px solid var(--gray-2);
}
.result-metric {
  display: flex; justify-content: space-between; align-items: baseline;
  margin-bottom: 8px;
}
.metric-before {
  font-size: 13px; color: var(--text-muted);
  text-decoration: line-through;
}
.metric-after {
  font-size: clamp(26px, 3vw, 36px);
  font-weight: 900; letter-spacing: -0.03em; color: var(--black);
}
.metric-unit { font-size: 14px; font-weight: 400; color: var(--text-muted); }
.metric-label {
  font-size: 11px; color: var(--text-muted); letter-spacing: 0.06em;
  text-transform: uppercase; margin-bottom: 24px;
}
.result-actions { margin-top: auto; }
.result-tag {
  display: inline-block; font-size: 10px; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  padding: 4px 12px; background: var(--gray-1);
  color: var(--text-mid); margin: 3px 3px 0 0;
}

.result-big {
  grid-column: 1 / -1; background: var(--black);
  padding: 56px 48px;
}
.result-big .result-industry { color: rgba(255,255,255,0.4); border-color: rgba(255,255,255,0.1); }
.result-big .result-metric-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 1px; background: rgba(255,255,255,0.1); margin: 32px 0;
}
.result-big .rb-stat { background: rgba(255,255,255,0.04); padding: 24px 20px; }
.result-big .rb-val {
  font-size: clamp(28px, 3.5vw, 44px); font-weight: 900;
  letter-spacing: -0.03em; color: var(--white); margin-bottom: 4px;
}
.result-big .rb-val .highlight { color: var(--accent-3); }
.result-big .rb-lbl { font-size: 11px; color: rgba(255,255,255,0.4); letter-spacing: 0.06em; text-transform: uppercase; }
.result-big .result-tag { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.6); }

/* ─── SKILLS ─── */
#skills { background: var(--white); }

.skills-layout {
  display: grid; grid-template-columns: 1fr 1.5fr;
  gap: 80px; align-items: start; margin-top: 56px;
}
.skill-category { margin-bottom: 40px; }
.skill-cat-title {
  font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--text-muted);
  margin-bottom: 16px; padding-bottom: 8px;
  border-bottom: 1px solid var(--gray-2);
}
.skill-bar-wrap { margin-bottom: 14px; }
.skill-bar-top {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 6px;
}
.skill-name { font-size: 13px; font-weight: 500; color: var(--text); }
.skill-pct { font-size: 12px; font-weight: 700; color: var(--accent); }
.skill-bar-bg { height: 3px; background: var(--gray-2); border-radius: 0; overflow: hidden; }
.skill-bar-fill {
  height: 100%; background: var(--black);
  border-radius: 0; transition: width 1.2s cubic-bezier(0.4,0,0.2,1);
  width: 0;
}
.skill-bar-fill.blue { background: var(--accent); }
.skill-bar-fill.red { background: var(--accent-2); }
.skill-bar-fill.green { background: var(--accent-3); }

.skill-tags-wrap { display: flex; flex-direction: column; gap: 1px; }
.skill-tag-row {
  background: var(--gray-1); padding: 16px 20px;
  display: flex; justify-content: space-between; align-items: center;
  transition: background 0.2s;
}
.skill-tag-row:hover { background: var(--black); }
.skill-tag-row:hover .stn { color: var(--white); }
.skill-tag-row:hover .stl { color: rgba(255,255,255,0.4); }
.stn { font-size: 14px; font-weight: 500; color: var(--text); transition: color 0.2s; }
.stl { font-size: 11px; color: var(--text-muted); letter-spacing: 0.06em; text-transform: uppercase; transition: color 0.2s; }

/* ─── EXPERIENCE ─── */
#experience { background: var(--cream); }
.exp-timeline { margin-top: 56px; }
.exp-item {
  display: grid; grid-template-columns: 200px 1fr;
  gap: 48px; padding: 40px 0;
  border-bottom: 1px solid var(--gray-2);
}
.exp-item:first-child { border-top: 1px solid var(--gray-2); }
.exp-left {}
.exp-period { font-size: 12px; font-weight: 700; letter-spacing: 0.08em; color: var(--text-muted); text-transform: uppercase; margin-bottom: 4px; }
.exp-co { font-size: 13px; color: var(--accent); font-weight: 500; }
.exp-role { font-size: 20px; font-weight: 700; letter-spacing: -0.02em; color: var(--black); margin-bottom: 12px; }
.exp-desc { font-size: 14px; color: var(--text-mid); line-height: 1.75; margin-bottom: 16px; }
.exp-bullets { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.exp-bullets li {
  font-size: 13px; color: var(--text-mid); display: flex; gap: 12px; line-height: 1.5;
}
.exp-bullets li::before { content: '→'; color: var(--accent); flex-shrink: 0; font-weight: 700; }

/* ─── KPI MATCH ─── */
#kpi { background: var(--black); padding: 80px 6%; }
.kpi-inner { max-width: 1200px; margin: 0 auto; }
.kpi-title { font-size: clamp(28px, 3.5vw, 44px); font-weight: 900; letter-spacing: -0.03em; color: var(--white); margin-bottom: 8px; }
.kpi-sub { font-size: 16px; color: rgba(255,255,255,0.4); margin-bottom: 56px; }
.kpi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; background: rgba(255,255,255,0.1); }
.kpi-card {
  background: rgba(255,255,255,0.04); padding: 36px 32px;
  transition: background 0.2s;
}
.kpi-card:hover { background: rgba(255,255,255,0.08); }
.kpi-icon { font-size: 24px; margin-bottom: 16px; }
.kpi-metric { font-size: 13px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 8px; }
.kpi-val { font-size: clamp(20px, 2.5vw, 28px); font-weight: 900; color: var(--white); letter-spacing: -0.02em; margin-bottom: 8px; }
.kpi-desc { font-size: 13px; color: rgba(255,255,255,0.4); line-height: 1.6; }

/* ─── TOOLS ─── */
#tools { background: var(--white); }
.tools-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; background: var(--gray-2); margin-top: 56px; }
.tool-card {
  background: var(--white); padding: 32px 28px;
  transition: background 0.2s, transform 0.2s;
}
.tool-card:hover { background: var(--black); }
.tool-card:hover .tool-name { color: var(--white); }
.tool-card:hover .tool-cat { color: rgba(255,255,255,0.4); }
.tool-name { font-size: 15px; font-weight: 700; color: var(--black); margin-bottom: 4px; transition: color 0.2s; }
.tool-cat { font-size: 11px; color: var(--text-muted); letter-spacing: 0.06em; text-transform: uppercase; transition: color 0.2s; }

/* ─── CONTACT ─── */
#contact { background: var(--accent); padding: 100px 6%; }
.contact-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
.contact-title { font-size: clamp(36px, 4.5vw, 60px); font-weight: 900; letter-spacing: -0.03em; color: var(--white); line-height: 1.05; margin-bottom: 20px; }
.contact-sub { font-size: 16px; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 36px; }
.contact-links { display: flex; flex-direction: column; gap: 2px; }
.contact-link {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16px 20px; background: rgba(255,255,255,0.12);
  text-decoration: none; transition: background 0.2s;
}
.contact-link:hover { background: rgba(255,255,255,0.22); }
.cl-label { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.6); }
.cl-value { font-size: 14px; font-weight: 500; color: var(--white); }
.cl-arrow { color: rgba(255,255,255,0.6); font-size: 18px; }

.contact-cta-box {
  background: var(--white); padding: 48px 44px;
}
.cta-tag { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; }
.cta-title { font-size: 26px; font-weight: 900; letter-spacing: -0.02em; color: var(--black); margin-bottom: 12px; }
.cta-sub { font-size: 14px; color: var(--text-mid); line-height: 1.7; margin-bottom: 28px; }
.btn-black {
  background: var(--black); color: var(--white);
  padding: 16px 32px; font-size: 12px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  text-decoration: none; display: inline-block;
  transition: all 0.2s;
}
.btn-black:hover { background: var(--accent); }
.cta-items { display: flex; flex-direction: column; gap: 10px; margin-top: 24px; }
.cta-item { font-size: 13px; color: var(--text-mid); display: flex; gap: 10px; }
.cta-item::before { content: '✓'; color: var(--accent-3); font-weight: 700; flex-shrink: 0; }

/* ─── FOOTER ─── */
footer {
  background: var(--black); padding: 24px 6%;
  display: flex; justify-content: space-between; align-items: center;
}
.foot-name { font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--white); }
.foot-copy { font-size: 11px; color: rgba(255,255,255,0.3); }

/* ─── SCROLL REVEAL ─── */
.reveal {
  opacity: 0; transform: translateY(24px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible { opacity: 1; transform: none; }
.reveal-d1 { transition-delay: 0.1s; }
.reveal-d2 { transition-delay: 0.2s; }
.reveal-d3 { transition-delay: 0.3s; }
.reveal-d4 { transition-delay: 0.4s; }

/* ─── RESPONSIVE ─── */
/* ─── RESPONSIVE — TABLET (768px – 1024px) ─── */
@media (max-width: 1024px) and (min-width: 769px) {
  nav { padding: 0 4%; }
  .nav-logo { font-size: 11px; }
  .nav-links { gap: 20px; }
  .nav-links a { font-size: 11px; }

  section { padding: 80px 4%; }
  #kpi { padding: 80px 4%; }
  #contact { padding: 80px 4%; }

  .hero-inner { grid-template-columns: 1fr; gap: 40px; padding-top: 20px; }
  .hero-bg-text { font-size: 130px; top: 50%; transform: translateY(-50%); opacity: 0.5; }
  .hero-right { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .hero-stat-row { max-width: 100%; }
  .hero-avail { grid-column: 1 / -1; }
  .platform-row { grid-column: 1 / -1; margin-top: 0 !important; }

  .why-grid { grid-template-columns: 1fr 1fr; }
  .why-card { padding: 32px 28px; }

  .result-grid { grid-template-columns: 1fr 1fr; }
  .result-big { grid-column: 1 / -1; }
  .result-big .result-metric-grid { grid-template-columns: repeat(2, 1fr); }
  .result-big { padding: 40px 36px; }

  .skills-layout { grid-template-columns: 1fr; gap: 40px; }

  .exp-item { grid-template-columns: 160px 1fr; gap: 32px; }

  .kpi-grid { grid-template-columns: 1fr 1fr; }

  .tools-grid { grid-template-columns: repeat(3, 1fr); }

  .contact-inner { grid-template-columns: 1fr; gap: 40px; }
  .contact-cta-box { padding: 36px 32px; }
}

/* ─── RESPONSIVE — MOBILE (≤768px) ─── */
@media (max-width: 768px) {
  nav { padding: 0 5%; }
  .nav-logo { font-size: 11px; max-width: 200px; line-height: 1.3; }
  .nav-links { display: none; }

